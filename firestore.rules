rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User documents
    match /users/{userId} {
      // Authenticated users (including anonymous) can read/write their own data
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Transactions subcollection (read-only for users, write by functions)
      match /transactions/{document=**} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null; // Cloud Functions can write
      }
      
      // Meals subcollection (user can read own meals, functions can write)
      match /meals/{document=**} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null; // Cloud Functions can write
      }
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
